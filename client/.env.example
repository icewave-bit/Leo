# Public site origin for SEO (canonical URLs, sitemap, Open Graph).
VITE_PUBLIC_ORIGIN=https://leo.super.net.by

# Production / Docker: API origin for browser fetch (e.g. https://api.yourdomain.com)
# Docker compose default: http://127.0.0.1:3001
# Один ingress (Traefik) на один origin — можно оставить пустым и маршрутизировать /api на бэкенд.
# VITE_API_URL=

# Dev only: Vite proxies /api to this target (browser uses same-origin /api)
VITE_API_PROXY_TARGET=http://127.0.0.1:3001
